# ─── LevlCast Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env.local and fill in every value before running locally.
# Never commit .env.local to git — it contains secrets.
#
# All NEXT_PUBLIC_ variables are exposed to the browser.
# All others are server-only.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
# Public anon key — safe to expose, enforced by Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — bypasses RLS. NEVER expose to the browser.
# Used only in API routes via createAdminClient().
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twitch ───────────────────────────────────────────────────────────────────
# Found in: dev.twitch.tv → Your Application → Client ID / Client Secret
# OAuth redirect URI must be: https://www.levlcast.com/auth/callback
# Required scopes: user:read:email, user:read:follows
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
# Used for: peak detection (Haiku model) and coaching reports (Sonnet model)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Deepgram ─────────────────────────────────────────────────────────────────
# Found in: console.deepgram.com → API Keys
# Used for: VOD audio transcription (Nova 3 model)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ─── YouTube ──────────────────────────────────────────────────────────────────
# Found in: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# OAuth redirect URI must be: https://www.levlcast.com/api/auth/youtube/callback
# Required scopes: https://www.googleapis.com/auth/youtube.upload
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# ─── TikTok ───────────────────────────────────────────────────────────────────
# Found in: developers.tiktok.com → Your App → Keys and Tokens
# Note: TikTok upload is coming soon — OAuth is wired but upload not fully live
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ─── PayPal ───────────────────────────────────────────────────────────────────
# Found in: developer.paypal.com → My Apps & Credentials
# Webhook must point to: https://www.levlcast.com/api/webhooks/paypal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
NEXT_PUBLIC_PAYPAL_PLAN_ID=your-paypal-plan-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# Set to "sandbox" locally, "live" in Vercel production
PAYPAL_ENV=sandbox

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# Found in: app.revenuecat.com → Project → API Keys
# Used for: iOS in-app subscription webhooks
REVENUECAT_SECRET_KEY=your-revenuecat-secret-key

# ─── Inngest ──────────────────────────────────────────────────────────────────
# Found in: app.inngest.com → Your App → Keys
# Used for: background VOD analysis jobs (transcription + AI pipeline)
# Leave blank locally — Inngest Dev Server uses a default key
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for OAuth redirects and OG image generation
# Set to http://localhost:3000 locally, https://www.levlcast.com in production
NEXT_PUBLIC_SITE_URL=https://www.levlcast.com
