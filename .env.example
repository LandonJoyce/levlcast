# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Twitch OAuth ──
# Create at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
NEXT_PUBLIC_TWITCH_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Anthropic (Claude) ──
# Peak detection + caption generation
ANTHROPIC_API_KEY=sk-ant-...

# ── Deepgram ──
# Transcription (batch mode, ~$0.0043/min)
# $200 free credits at signup: https://deepgram.com
DEEPGRAM_API_KEY=your-deepgram-key

# ── RevenueCat ──
# Web subscription management
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY=your-rc-public-key
REVENUECAT_API_KEY=your-rc-secret-key
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret

# ── Inngest ──
# Background job orchestration
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# ── Social APIs (Phase 5+) ──
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# ── App Config ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
